generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Lead {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  email       String
  companyName String
  contactName String?
  source      String   @default("web")
  website     String?
  linkedinUrl String?
  phone       String?
  status      String   @default("NEW")
  assignedTo  String?
  priority    String   @default("NORMAL")
  notes       String?

  qualification LeadQualification?
  demandAnalysis DemandAnalysis?
  triageReview   TriageReview?
  offerDraft     OfferDraft?
  riskAssessment RiskAssessment?
  presentation   Presentation?
  contract       Contract?
  handoverBrief  HandoverBrief?
  negotiations   Negotiation[]
  activityLogs   ActivityLog[]

  @@index([status])
  @@index([createdAt])
}

model LeadQualification {
  id              String   @id @default(cuid())
  leadId          String   @unique
  lead            Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  qualityScore    Int
  confidence      String
  recommendation  String
  reasoning       String
  scrapedData     String
  checkedAt       DateTime @default(now())
}

model DemandAnalysis {
  id                 String   @id @default(cuid())
  leadId             String   @unique
  lead               Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  estimatedBudget    String
  decisionMakerLevel String
  currentTools      String
  painPoints        String
  expectedSalesCycle Int
  missingDataPoints String
  demandScore       Int
  analyzedAt        DateTime @default(now())
}

model TriageReview {
  id                String   @id @default(cuid())
  leadId            String   @unique
  lead              Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  demandScore       Int
  thesis            String
  recommendedAction String
  confidence        String
  comparedToWon     Int?
  comparedToLost   Int?
  triagedAt         DateTime @default(now())
}

model OfferDraft {
  id                 String   @id @default(cuid())
  leadId             String   @unique
  lead               Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  pricingModel       String
  proposedPriceLow   Int?
  proposedPriceMid   Int?
  proposedPriceHigh  Int?
  discountOffer      String?
  offerTerms         String
  valueProposition   String
  differentiators    String
  implementationPlan String?
  nextSteps          String
  draftedAt         DateTime @default(now())
  reviewedBy        String?
  reviewedAt        DateTime?
  approved          Boolean  @default(false)
}

model RiskAssessment {
  id                      String   @id @default(cuid())
  leadId                  String   @unique
  lead                    Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  marginRisk             Boolean  @default(false)
  timelineRisk           Boolean  @default(false)
  scopeRisk              Boolean  @default(false)
  technicalFitRisk       Boolean  @default(false)
  flags                  String
  riskScore              Int
  recommendedAdjustments String?
  assessedAt             DateTime @default(now())
}

model Presentation {
  id         String   @id @default(cuid())
  leadId     String   @unique
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  deckUrl    String
  emailDraft String
  deckSlides String
  status     String   @default("READY")
  sentAt     DateTime?
  sentBy     String?
  openedAt   DateTime?
}

model Negotiation {
  id                 String    @id @default(cuid())
  leadId             String
  lead               Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  threadId           String?
  clientMessage      String
  sentiment          String
  objections         String
  suggestedConcession String?
  suggestedReply     String
  priceChange        Int?
  timelineChange     Int?
  additionalTerms     String?
  createdAt          DateTime  @default(now())
  resolved           Boolean   @default(false)
  resolvedAt         DateTime?

  @@index([leadId])
}

model Contract {
  id             String    @id @default(cuid())
  leadId         String    @unique
  lead           Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  contractUrl    String
  status         String    @default("DRAFT")
  termsSnapshot  String
  sentAt         DateTime?
  viewedAt       DateTime?
  signedAt       DateTime?
  reminderSet    Boolean   @default(false)
  rejectedReason String?
  notes          String?
}

model HandoverBrief {
  id                   String    @id @default(cuid())
  leadId               String    @unique
  lead                 Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  roadmapSlug          String    @unique
  onboardingChecklist  String
  projectBrief         String
  artifactsBundlePath   String?
  deliveryTeamNotified Boolean   @default(false)
  notifiedAt           DateTime?
  status               String    @default("READY_FOR_REVIEW")
  createdBy            String?
  createdAt            DateTime  @default(now())
  deliveredAt          DateTime?
}

model ActivityLog {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  agent       String
  action      String
  description String?
  metadata    String?
  createdAt   DateTime @default(now())

  @@index([leadId])
  @@index([createdAt])
}
